# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# 
# LOCAL DEVELOPMENT (SQLite):
DATABASE_URL="file:./prisma/dev.db"

# PRODUCTION/CLOUD (PostgreSQL):
# Get your DATABASE_URL from cloud provider (Vercel, Railway, etc.):
# 1. Create PostgreSQL database on your cloud platform
# 2. Copy the connection string
# 3. Uncomment the line below and paste your connection string
# DATABASE_URL="postgresql://username:password@host:port/database"

# ============================================================================
# NEXTAUTH CONFIGURATION
# ============================================================================
# Generate a secure secret: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-random-secure-string-here-minimum-32-characters"

# For development (http://localhost:3000)
NEXTAUTH_URL="http://localhost:3000"

# For production (replace with your deployed domain)
# NEXTAUTH_URL="https://yourdomain.com"

# ============================================================================
# ADMIN REGISTRATION CODE
# ============================================================================
# Required code for admin registration
ADMIN_REGISTRATION_CODE="110238870"

# ============================================================================
# OPTIONAL: FILE UPLOAD SERVICE
# ============================================================================
# If you want file uploads for gig attachments/project files
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
# CLOUDINARY_API_KEY="your-api-key"
# CLOUDINARY_API_SECRET="your-api-secret"
